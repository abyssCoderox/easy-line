# 服务配置
PORT=3000
NODE_ENV=development

# Chat API 安全配置
API_KEY=your-secure-api-key-here

# LINE配置
LINE_CHANNEL_SECRET=your-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-access-token

# LLM配置
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-openai-api-key
LLM_MODEL=gpt-3.5-turbo
LLM_API_BASE_URL=
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000
LLM_TIMEOUT=30000
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1000
LLM_FALLBACK_RESPONSE=抱歉，我暂时无法回答，请稍后再试。
LLM_MAX_HISTORY_LENGTH=6

# 向后兼容（旧配置名，优先级低于 LLM_API_KEY）
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_API_BASE=

# Agent 配置
ALERT_API_URL=https://api.example.com/alerts
DEVICE_API_URL=https://api.example.com/devices
AGENT_MAX_ITERATIONS=3
AGENT_TIMEOUT=30000

# 告警服务配置
ALARM_API_BASE_URL=http://localhost:8000
ALARM_API_TIMEOUT=60000

# Dify 工作流配置（工单创建）
DIFY_WORKFLOW_URL=http://192.168.100.225:8088
DIFY_API_KEY=app-xxxxxxxx
DIFY_USER=langchain-agent

# 默认业务上下文（可选，用于工单创建）
DEFAULT_TENANT_ID=
DEFAULT_PMMS_AUTHORIZATION=

# Flex Message 构建方式（可选）
# code: 使用代码构建（默认，快速稳定）
# llm: 使用大模型构建（更灵活，适应性强）
FLEX_MESSAGE_BUILDER=code

# Tavily 搜索配置
TAVILY_API_KEY=tvly-your-api-key-here
TAVILY_MAX_RESULTS=5
TAVILY_SEARCH_DEPTH=basic

# 第三方API密钥（可选）
WEATHER_API_KEY=your-weather-api-key
NEWS_API_KEY=your-news-api-key

# 日志配置
LOG_LEVEL=info
LOG_DIR=logs
LOG_MAX_FILE_SIZE=10485760
LOG_MAX_FILES=30
LOG_CONSOLE=true
LOG_REQUEST_BODY=false
